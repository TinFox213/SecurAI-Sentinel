# SecurAI Sentinel Environment Configuration
# Copy this file to .env and add your real values.

# AI provider routing
# The backend tries configured providers in AI_PROVIDER_ORDER when AI_PROVIDER=auto.
AI_PROVIDER=auto
AI_PROVIDER_ORDER=gemini,openrouter,nvidia
AI_REQUEST_TIMEOUT_MS=45000
AI_MAX_TOKENS=4096

# Gemini API key (already supported)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter API key (optional; add when available)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SecurAI Sentinel

# NVIDIA API key (optional; add when available)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# HaveIBeenPwned API key (https://haveibeenpwned.com/API/Key)
# Required for Dark Web Monitor email/domain/paste checks.
HIBP_API_KEY=your_hibp_api_key_here

# AbuseIPDB API key (https://www.abuseipdb.com/account/api)
# Required for Dark Web Monitor IP reputation checks.
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
